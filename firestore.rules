rules_version = '2';

// Deploy: npm run deploy:rules  (from event-site/)
//
// First signup = create. Re-using the same email path = update → denied → duplicate in the app.
// Keep `allow create` permissive so field-level quirks in rules never block *every* new registration
// (that used to surface as permission-denied and was mislabeled “email already registered”).
// Tighten later with App Check / Cloud Functions if you need stricter validation.

service cloud.firestore {
  match /databases/{database}/documents {
    match /p0_registrations/{docId} {
      // Admin-only reads for the dashboard (set this UID in Firebase Auth).
      // Replace ADMIN_UID_HERE with your admin user's UID from the Firebase console.
      function isAdmin() {
        return request.auth != null && request.auth.uid == "Of8Gn0pshiYbJgGh5096VwmMUEs2";
      }

      allow get, list: if isAdmin();
      allow create: if true;
      // Allow admin to mark participants as contacted (and only that).
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["contacted", "contactedAt"])
        && request.resource.data.contacted is bool;
      allow delete: if false;
    }
  }
}
